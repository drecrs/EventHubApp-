<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EventHubApp.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Register"
    Shell.FlyoutBehavior =" Disabled">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="12">

            <Label Text="Create Account"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Full Name"
                   Text="{Binding Name}" />

            <Entry Placeholder="Email"
                   Keyboard="Email"
                   Text="{Binding Email}" />

            <Entry Placeholder="Password"
                   IsPassword="True"
                   Text="{Binding Password}" />

            <Entry Placeholder="Parish"
                   Text="{Binding Parish}" />

            <Entry Placeholder="Country"
                   Text="{Binding Country}" />

            <Picker Title="Select User Type"
                    ItemsSource="{Binding UserTypes}"
                    SelectedItem="{Binding UserType}" />

            <Button Text="Register"
                    Command="{Binding RegisterCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
